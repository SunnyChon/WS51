  15          /* 
  16          计数时钟为慢速时钟（由寄存器 LRCON的 LRS 位决定是是 LOSC 还是 LRC 时钟）
  17          WDTS_T(timeval)
  18          WDT 时间选择
  19          0： 256 个时钟周期，约为 7.8125ms
  20          1： 512 个时钟周期，约为 15.625ms
  21          2： 1024 个时钟周期，约为 31.25ms
  22          3： 2048 个时钟周期，约为 62.5ms
  23          4： 4096 个时钟周期，约为 125ms
  24          5： 8192 个时钟周期，约为 250ms
  25          6： 16384 个时钟周期，约为 500ms
  26          7： 32768 个时钟周期，约为 1s
  27          */
  28          
  29          //========================================================================
  30          // 函数: void WDT_init (u8 isr_en,u8 sval)
  31          // 描述: 
  32          // 参数: isr_en:中断使能(ENABLE,DISABLE0),
  33          //       sval:分频系数(取值0-7)
  34          // 返回: 
  35          // 版本: 
  36          //========================================================================
  37          void WDT_init(u8 isr_en,u8 sval)
  38          {
  39   1          if(sval>7) return;
  40   1          
  41   1          if(isr_en == ENABLE)
  42   1          {
  43   2              WDTINT_EN();  
  44   2          }
  45   1          else
  46   1          {
  47   2              WDTRES_EN();//使能 WDT, WDT 溢出后产生复位
  48   2          }
  49   1          WDTS_T(sval);
  50   1          WDT_CLR();
  51   1      }
