   4          /********************* WDT_isr中断函数************************/
   5          void WDT_isr (void) interrupt 6
   6          {
   7   1          if(0x02 == (WDTFLG&WDIF))
   8   1          {
   9   2              P00 = ! P00;
  10   2              WDT_CLR();
  11   2          }
  12   1      }
