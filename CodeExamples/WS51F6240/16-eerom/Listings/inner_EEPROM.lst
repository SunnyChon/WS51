  18          /*****************************************************
  19          *函数名称：void writeData2EEPROM(unsigned char *buf,unsigned short SectorAddr,unsigned short len)
  20          *函数功能：EEPROM写
  21          *入口参数：buf,要写入数据的指针
  22                             SectorAddr 地址
  23                             len,写入长度
  24          *出口参数：void
  25          *****************************************************/
  26          void writeData2EEPROM(unsigned char *buf,unsigned short SectorAddr,unsigned short len)
  27          {
  28   1              unsigned char i=0;
  29   1              //1 EPPROM Unlock
  30   1              FSFLG=INNER_EPPROM_UNLOCK;
  31   1              //2 EEPROM Enable write
  32   1              FSCMD=INNER_EPPROM_WRITE_CMD;
  33   1              for(i=0;i<len;++i)
  34   1              {
  35   2                      //3  write address              
  36   2                      FSADRL=(SectorAddr&0xff);
  37   2                      FSADRH=((SectorAddr>>8)&0xff);
  38   2                      SectorAddr++;
  39   2                      //4 write data
  40   2                      FSDAT=buf[i];
C51 COMPILER V9.59.0.0   INNER_EEPROM                                                      10/28/2020 16:04:42 PAGE 10  

  41   2              }
  42   1              //4 NVR lock
  43   1              FSFLG=INNER_EPPROM_LOCK;
  44   1      }
