  74          /**
  75          * @brief  使用SPI发送一个字节的数据
  76          * @param  byte：要发送的数据
  77          * @retval 返回接收到的数据
  78          */
  79          u8 SPI_SendByte(u8 byte)
  80          {
  81   1                      u8 rDat0;
  82   1        
  83   1              /* 写入数据寄存器，把要写入的数据写入发送缓冲区 */
  84   1          while((SPFLG & 0x04) == 0x04);//写入冲突标志位
  85   1          SPDAT = byte;
  86   1      
  87   1          //transfer finish
  88   1          while((SPFLG & 0x01) == 0); 
  89   1          SPFLG &= 0xfe;
  90   1          
  91   1              /* 读取数据寄存器，获取接收缓冲区数据 */
  92   1          rDat0 = SPDAT;
  93   1                      return rDat0;
  94   1      }
