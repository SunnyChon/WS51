  59          /*****************************************************
  60          *函数名称：void SPI_Init(void)
  61          *函数功能：SPI_FLASH初始化 作为从机
  62          *入口参数：
  63          *出口参数：
  64          *****************************************************/
  65          void SPI_Init(void)
  66          {       
  67   1              /* SPI 模式配置 */
  68   1              // FLASH芯片 支持SPI模式0及模式3，据此设置CPOL CPHA
  69   1          SPCON=SPEN+CPOL+CKOS+SSIG;//
  70   1              // 使能、+LSBF/高低位优先、/SPI_CS、+MSTR从主模式、/极性、+CPHA/相位、/输出时钟
  71   1                      SPFLG = 0+0x80; ///中断使能位, +0x40/单数据线模式选择位
  72   1      }
