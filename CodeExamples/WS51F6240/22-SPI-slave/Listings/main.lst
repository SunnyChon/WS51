  27   1              S1RELH = 972>>8;        //9600
  28   1      //      S1RELL = 1020;
  29   1      //      S1RELH = 1020>>8;       //115200
  30   1      }
  31          
  32          void UART1_write(signed char dat)
  33          {
  34   1          S1BUF = dat;            //Send data to UART buffer
  35   1          while(TI1 != (S1CON&TI1));
  36   1          //清TI1
  37   1          S1CON &= ~TI1;
  38   1      }
