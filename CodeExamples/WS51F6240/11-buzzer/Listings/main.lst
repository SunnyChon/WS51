  11          /*********************************buzzer简介********************************************
  12          WS51F0032 系列芯片有 1 路蜂鸣器驱动输出，可选工作时钟，对该时钟进行 1-64 分频后进行 0-256 
  13          周期和占空比调整。
  14          频率：f=clk/(BZPSC+1)/(BZDIV+1)
  15          *************************************************************************************/
  16          #include "WS51F6240.h"  
  17          
  18          static void delay_1ms(void)
  19          {
  20   1              int j;
  21   1              for(j=0;j<1700;++j);
  22   1      }
  23          
  24          static void delay(int i)
  25          {
  26   1              long j;
  27   1              for(j=0;j<10*i;++j);
  28   1      }
  29          /*****************************************************
  30          *函数名称：init_buzzer(void)
  31          *函数功能：buzzer初始化
  32          *入口参数：
  33          *出口参数：
  34          *****************************************************/
  35          void init_buzzer(void)
  36          {
  37   1              BZCON = 0+0xc0; //+0x01/极性选择0, +0x40,+0x80,+0xC0,/时钟选择bit7-6 (0-无，1-LRC，2-LOSC，3-HRC)
  38   1              BZPSC = 0;                  //系统时钟预分频配置寄存器，分频倍数为 BZPSC+1
  39   1              BZDUT = 50;               //蜂鸣器驱动高电平所持续的分频时钟个数
  40   1              BZDIV = 99;             
  41   1      }
  42          
  43          /**************************************************************
  44          说明：若使用外部时钟则把if 0 变为if 1
  45          ***************************************************************/
  46          void main()
  47          {
  48   1                SCCON = 0x00;//HRC
  49   1                HRCON |= 0X80;
  50   1      
  51   1      #if 0 
              /*********************外部losc时钟配置*****************/
                      /****************管脚配置       *************/
                  P17F = 5;
C51 COMPILER V9.59.0.0   MAIN                                                              07/26/2021 15:48:14 PAGE 2   

                      P21F = 5;
                      
                  //使能SCM
                  SCMCON = 0x08+0x02; //+0x04
                  
                  //配置外部时钟使能
                  XSCON = 0x08;
                  
                  //等待外部时钟稳定
                  while((XSCON&0x01)==0x0);
                              delay_1ms();
                      
                  //切换系统时钟为外部低速 RC
              //      SCCON = 0x40;//LOSC 
              #endif
  70   1       
  71   1               /*************** 管脚配置 ****************/    
  72   1                P11F = 0X02; 
  73   1                P15F = 2;     //蜂鸣器 管脚
  74   1      
  75   1               /********** 50%占空比的蜂鸣器 ************/
  76   1          init_buzzer();
  77   1              
  78   1              while(1);
  79   1      
  80   1      }
