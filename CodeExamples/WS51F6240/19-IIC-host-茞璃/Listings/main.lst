 397          /*****************************************************
 398          *函数名称：void I2C_Init(void)
 399          *函数功能：IIC配置初始化
 400          *入口参数：
 401          *出口参数：
 402          *****************************************************/
 403          void I2C_Init(void)
 404          {
 405   1              /*********************************** IIC 配置寄存器 ***********************************
 406   1              /*      
 407   1              寄存器 I2CCON           +I2CE   0x80    bit7：I2C 模块使能位， 1 有效
 408   1                                                      +I2CIE  0x40    bit6：I2C 中断使能位， 1 有效
 409   1                                                      +STAIE  0x20    bit5：总线出现 START 信号，中断使能信号
 410   1                                                      +STPIE  0x10    bit4：总线出现 STOP 信号，中断使能信号
 411   1                                                      +STA    0x08    bit3：发送 START 信号
 412   1                                                      +STP    0x04    bit2：发送 STOP 信号
 413   1                                                      +I2CKD  0x00    bit1-0：I2C 时钟分频选择寄存器
 414   1                                                                                              00： I2C 模块时钟Fiic选择内部 16MHz 高速时钟
 415   1                                                                                              01： I2C 模块时钟Fiic选择内部 16MHz 高速时钟/2
 416   1                                                                                              10： I2C 模块时钟Fiic选择内部 16MHz 高速时钟/4
 417   1                                                                                              11： I2C 模块时钟Fiic选择内部 16MHz 高速时钟/8
 418   1              
 419   1              寄存器 I2CCON           +I2CCKD 0x00    bit6-0：(127~0)
 420   1                                                                                      I2C 作为 master 输出数据频率选择 Fiic/(I2CCKD + 8)
 421   1              
 422   1              寄存器 I2CFLG标志位     BUSIDLE         0x80 总线状态标志（只读）
 423   1                                                      RXNAK           0x40 总线接收响应标志（只读）
 424   1                                                      IF_LSTARB       0x20 I2C 发送的数据和接收到的数据不一致时出现总线丢失，高有效，写 0 清
 425   1                                                      IF_RXSTA        0x10 总线接收到 START 信号
 426   1                                                      IF_RXSTP        0x08 总线接收到 STOP 信号
C51 COMPILER V9.59.0.0   MAIN                                                              07/01/2022 16:00:39 PAGE 8   

 427   1                                                      IF_TXDAT        0x04 当 I2C 为主机时表明已发送一个字节数据并接收到响应标志
 428   1                                                      IF_RXDAT        0x02 接收一个字节数据完成
 429   1                                                      IF_RXADR        0x01 I2C 作为从机正确接收到从机地址
 430   1              **/
 431   1              
 432   1              /* 配置 IIC 时钟频率 119K */
 433   1      //    I2CCON = 0x03;//Fi2c_CLK====== 16M   16M/2   16M/4  16M/8
 434   1      //    I2CFG1 = 0x7f;  //Fi2c/(I2CFG1<6:0>+8) 
 435   1          //127+8  
 436   1          //00_ff:2M~ 119K ok
 437   1          //01_ff:1M~ 59K  
 438   1          //02_ff:500K~ 29K  
 439   1          //03_ff:250L~ 最慢 14K 
 440   1          //最大: 00_00: 2M
 441   1          
 442   1          
 443   1          I2CCON = 0x00;//Fi2c_CLK====== 16M
 444   1          I2CFG1 = 0xff;  //Fi2c/(I2CFG1<6:0>+8) 
 445   1          
 446   1          
 447   1          I2CFLG  = 0x0;              //清标志
 448   1          I2CCON  |= (0x1<<7);    //MODE en
 449   1      //    I2CCON  |= (0x1<<6);  //interrupt en
 450   1      //    I2CCON  &= ~(0x1<<7);   
 451   1          I2CCON  &= ~(0x1<<6);       //不开中断
 452   1          
 453   1      //    I2CCON  |= (0x1<<5);  //START INT EN 中断使能
 454   1      //    I2CCON  |= (0x1<<4);  //STOP INT EN
 455   1          I2CCON  &= ~(0x1<<5);  //不开 START INT EN
 456   1          I2CCON  &= ~(0x1<<4);  //不开 STOP INT EN
 457   1          
 458   1      }
