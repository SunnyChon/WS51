  61                                  看P11翻转时间 若使用外部时钟losc则把if 0 变为if 1
  62          ***************************************************************/
  63          void main()
  64          {    
  65   1                      SCCON = 0x00;//HRC  
  66   1                      HRCON |= 0x80;  
  67   1      #if 0 
              /*********************外部losc时钟配置*****************/
                      /****************管脚配置       *************/
                  P17F = 5;
                      P21F = 5;
                      
                  //使能SCM
                  SCMCON = 0x08+0x02; //+0x04
                  
                  //配置外部时钟使能
                  XSCON = 0x08;
                  
                  //等待外部时钟稳定
                  while((XSCON&0x01)==0x0);
                              delay_1ms();
                      
                  //切换系统时钟为外部低速 RC
              //      SCCON = 0x40;//LOSC 
              #endif
  86   1              /*************** 管脚配置 ****************/     
  87   1               P11F=0X02; 
  88   1      
  89   1              /*************** 自唤醒定时器 初始化 ****************/  
  90   1               init_wkt();
  91   1              
  92   1               IE = 0XC0;   
  93   1               while(1);
