  16          *函数名称：void Uart1Mode1(void)
  17          *函数功能：9600波特率
  18          *入口参数：
  19          *出口参数：
  20          *****************************************************/
  21          void Uart1Mode1(void)
  22          {
  23   1              S1CON = 0x80;   ///8位异步模式(1), +0x10/中断使能, +0x20/多机通信使能位, +0x40/串行接收使能位
  24   1              S1RELL = 972;
  25   1              S1RELH = 972>>8;
  26   1      }
  27          
  28          void UART1_write(signed char dat)
  29          {
  30   1          S1BUF = dat;            //Send data to UART buffer
  31   1          while(TI1 != (S1CON&TI1));
  32   1          //清TI1
  33   1          S1CON &= ~TI1;
  34   1      }
  35          
  36          ///重定向c库函数printf到串口，重定向后可使用printf函数
  37          char putchar(char ch)
  38          {
  39   1          /* 发送一个字节数据到串口 */
  40   1          UART1_write((signed char) ch);
  41   1              
  42   1          return ch;
  43   1      }
