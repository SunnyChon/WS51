  10          #include "WS51F6240.h"
  11          
  12          /* 
  13          * timer0和timer1, 进入中断函数会自动清标志
  14          * Timer0: 模式选择
  15          *                       (1).模式0: 定时器 0 作为 13 位定时器/计数器
  16          *               (2).模式1: 定时器 0 作为 16 位定时器/计数器
  17          *               (3).模式2: 定时器 0 作为 8 位自动重载定时器/计数器
  18          *               (4).模式3: TL0 和 TH0 作为两个独立的 8 位定时器/计数器
  19          * Timer1: 模式选择
  20          *                       (1).模式0: 定时器 1 作为 13 位定时器/计数器
  21          *               (2).模式1: 定时器 1 作为 16 位定时器/计数器
  22          *               (3).模式2: 定时器 1 作为 8 位自动重载定时器/计数器
  23          *               (4).模式3: 此模式下，TH1、TL1 会被锁住，等效于 TR1=0。
  24          * Timer0/1: 管脚配置
  25          *                       (1).计数功能, 管脚T0(P05)设置为输入(P05F = 0x1;)
  26          *                       (2).计数功能, 管脚T1(P00)设置为输入(P00F = 0x1;)
  27          
  28                                  定时时间 = ((最大计数值-初始值)*12*1000*1000) / 晶振频率
  29                初始值   =  定时时间*晶振频率/分频系数
  30                                  晶振频率(16*1000*1000 或 32*1000)
  31          */
  32          
  33          /*****************************************************
  34          *函数名称：void init_timer0(void)
  35          *函数功能：Timer0初始化配置
  36          *入口参数：
  37          *出口参数：
  38          *****************************************************/
  39          void init_timer0(void)
  40          {
  41   1              
  42   1              //工作模式0：13 位定时器/计数器，计满6.1440ms(13bit)    
  43   1          TL0 = (8192-1334) & 0x1F;       //初始值低字节，TL0 的高 3 位是无效的
  44   1          TH0 = (8192-1334) >> 5;         //初始值高字节(1ms@16MHz)  0.993ms
  45   1              TMOD = 0x00;                      //定时器,时钟为系统时钟 12 分频 
  46   1              
  47   1              //工作模式1：16 位定时器，计满49.152ms(16bit)
  48   1      //    TL0 = (65536-1334);       
  49   1      //    TH0 = (65536-1334) >> 8;      
  50   1      //    TMOD = 0x01;                      //模式，+0x04计数定时选择，+0x08门控选择
  51   1      
  52   1              //工作模式2：8 位自动重载定时器，计满0.192ms(8bit)
  53   1      //    TH0 = 0;       
  54   1      //    TL0 = 256-134    ;        //重载值为(256-134); 定时100us  
C51 COMPILER V9.59.0.0   MAIN                                                              02/10/2022 10:32:40 PAGE 2   

  55   1      //    TMOD = 0x02;
  56   1      
  57   1              //工作模式3：2个 8 位定时器，计满0.192ms(8bit)
  58   1      //    TL0 = 0;       
  59   1      //    TH0 = 0;      
  60   1      //    TMOD = 0x03;                      //模式，+0x04计数定时选择，+0x08门控选择        
  61   1                                                                      
  62   1          ET0 = 1;    //开中断 定时器 0 中断使能控制位
  63   1          EA = 1;             //总中断
  64   1          TR0 = 1;    //启动定时器
  65   1      }
  66          
  67          
  68          /*****************************************************
  69          * 中断服务函数
  70          *****************************************************/
  71          void timer0_isr (void) interrupt 1  
  72          {
  73   1        /* set timer0 as mode0 (13-bit) */
  74   1          TL0 = (8192-1334) & 0x1F;       //初始值低字节，TL0 的高 3 位是无效的 
  75   1          TH0 = (8192-1334) >> 5;         //初始值高字节(1ms@16MHz)
  76   1              
  77   1              /* 工作模式1：16 位定时器 */
  78   1      //    TL0 = (65536-1334);       
  79   1      //    TH0 = (65536-1334) >> 8;  
  80   1              
  81   1              /* 工作模式2：8 位自动重载定时器,重载寄存器 TH0 */  
  82   1      //       TH0 = 0;       
  83   1      //   TL0 = 256-134;     //重载值为(256-134); 定时100us
  84   1              
  85   1              /* 工作模式3：两个 8 位定时器(TL0,TH0) */
  86   1      //    TL0 = 0;    
  87   1      
  88   1                  P10 = ~P10;
  89   1      }
  90          
  91          
  92          /**************************************************************
  93          说明：例程校准好时钟，工作模式0/1定时约为1ms，工作模式2定时约为100us,
  94                                                                                                  工作模式3定时约为0.192ms
  95          ***************************************************************/
  96          void main()
  97          {    
  98   1                      SCCON = 0x00;//HRC  
  99   1                      HRCON |= 0x80;  
 100   1      
 101   1                      /**************** 管脚配置 ****************/
 102   1                      P10F = 0X02;      //推挽输出 Timer0中断
 103   1                      P05F = 0x81;      //计数功能, 管脚T0(P05)
 104   1      
 105   1                      /************* Timer0初始化配置 *************/
 106   1                      init_timer0();
 107   1              
 108   1          while(1);
 109   1      }  


