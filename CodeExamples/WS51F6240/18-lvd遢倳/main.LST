  59   1          /*************** UART0 模式1（波特率：9600）****************/
  60   1          SM00 = 0;
  61   1          SM10 = 1;
  62   1          REN0 = 0;    //串行接收使能位
  63   1          RI0 = 0;     //接收中断标志
  64   1          TI0 = 0;     //发送中断标志
  65   1          
  66   1              //TIMER2 作为uart0的波特率时钟源
  67   1          TR2 = 0;
  68   1          T2MOD = 0x00;/* 定时2中断不使能，不分频 */
  69   1          T2CL = 65536 - 52;
  70   1          T2CH = 65536 - 52 >> 8;
  71   1          TL2 = T2CL;
  72   1          TH2 = T2CH;
  73   1          TR2 = 1;    //启动定时器2
  74   1          RCLK = 1;
  75   1          TCLK = 1;   
  76   1      }
