  82          /**
  83          * @brief  使用SPI发送一个字节的数据
  84          * @param  byte：要发送的数据
  85          * @retval 返回接收到的数据
  86          */
  87          u8 SPI_SendByte(u8 byte)
  88          {
  89   1              u8 rDat;
  90   1        
  91   1              /* 写入数据寄存器，把要写入的数据写入发送缓冲区 */
  92   1          while((SPFLG & 0x04) == 0x04);//写入冲突标志位
  93   1          SPDAT = byte;
  94   1      
  95   1          //transfer finish
  96   1          while((SPFLG & 0x01) == 0); 
  97   1          SPFLG &= 0xfe;
  98   1          
  99   1              /* 读取数据寄存器，获取接收缓冲区数据 */
 100   1          rDat = SPDAT;
 101   1              return rDat;
 102   1      }
