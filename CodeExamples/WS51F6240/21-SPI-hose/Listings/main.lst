  64          /*****************************************************
  65          *函数名称：void SPI_Init(void)
  66          *函数功能：SPI_FLASH初始化 作为主机
  67          *入口参数：
  68          *出口参数：
  69          *****************************************************/
  70          void SPI_Init(void)
  71          {
  72   1              /* 停止信号 FLASH: CS引脚高电平*/
  73   1          SPI_CS_HIGH();  //P13 = 1
  74   1              
  75   1              /* SPI 模式配置 */
  76   1              // FLASH芯片 支持SPI模式0及模式3，据此设置CPOL CPHA
  77   1          SPCON=SPEN+MSTR+CPOL+CKOS;//
  78   1              // 使能、+LSBF/高低位优先、+SSIG/SPI_CS、从主模式、/极性、+CPHA/相位、/输出时钟
  79   1                      SPFLG = 0;      //+0x80/中断使能位, +0x40/单数据线模式选择位
  80   1      }
