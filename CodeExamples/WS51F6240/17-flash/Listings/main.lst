  56          *****************************************************/
  57          void writeHex(unsigned char num)
  58          {
  59   1              unsigned char i=0;
  60   1              i=num/16;
  61   1              if(i>9)UART0_write(i-10+'A');
  62   1              else UART0_write(i+'0');
  63   1              i=num%16;
  64   1              if(i>9)UART0_write(i-10+'A');
  65   1              else UART0_write(i+'0');
  66   1              UART0_write(' ');
  67   1      }
