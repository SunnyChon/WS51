  10          #include "WS51F6240.h"
  11          #include "intrins.h"
  12          
  13          // 寄存器 IDLF 和 STPF 是只读,不能写。
  14          
  15          // IDLE 模式
  16          // 1、进入 IDLE 模式前，除了主时钟，其他的时钟源可根据需要选择关闭, 
  17          // 同样进入 IDLE 模式前，可根据需要设定芯片某些外设的开关，打开的外设在 IDLE 下仍然可以正常工作。
  18          // 2、IDLF 事件标志需要处理完成, 才能进入 IDLE 模式
  19          // 3、IDLE 模式下, 所有复位事件和任何中断事件都将唤醒芯片
  20          // 4、需要注意的是，在置位 IDLE（PCON[0]）的指令后面需要紧接4条 nop 指令，防止程序出错。
  21          
  22          // STOP 模式
  23          // 1、STOP 模式可以停止所有时钟（包括主时钟）和时钟产生电路。
  24          // 如果 WDT 和 WKT 处于打开状态，则它们使用的时钟模块将处于工作状态。
  25          // 2、STPF 事件标志需要处理完成, 才能进入 STOP 模式
  26          // 3、STOP 模式下, 外部中断、LVD 中断或复位、外部硬复位、WKT 中断、WDT 中断或复位﹑触摸中断来唤醒
  27          // 4、需要注意的是，在置位 STOP 的指令后面需要紧接4条 nop 指令，防止程序出错。
  28          
  29          static void delay(int i)
  30          {
  31   1              long j;
  32   1              for(j=0;j<10*i;++j);
  33   1      }
  34          
  35          static void delay_1ms(void)
  36          {
  37   1              int j;
  38   1              for(j=0;j<1700;++j);
  39   1      }
  40          
  41          static void delay_10ms(void)
  42          {
  43   1              int j;
  44   1              for(j=0;j<17700;++j);
  45   1      }
  46          
  47          /*****************************************************
  48          *函数名称：void enterStop(void)
  49          *函数功能：
  50          *入口参数：
  51          *出口参数：
  52          *****************************************************/
  53          void enterStop(void)
  54          {
C51 COMPILER V9.59.0.0   MAIN                                                              08/10/2022 18:15:25 PAGE 2   

  55   1              if(STPF == 0)
  56   1              {                       
  57   2                              P01F=0x00;      
  58   2                              P00F=0x00;                      
  59   2                      
  60   2                      //关掉相关外设
  61   2                      LVDCON = 0x00;
  62   2                      I2CCON = 0x10;//总线出现STOP信号，中断使能信号
  63   2      //              ADCON=0x10;
  64   2      //              ADCFG=0x00;
  65   2                      HRCON &= 0x7f;
  66   2                      LRCON &= 0x7f;  
  67   2                      XSCON = 0x00;           
  68   2                      TKCON = 0x00;
  69   2      
  70   2                      SCCON = 0x00;
  71   2                      MECON |= 0X80;  //IDLE/STOP 模式下，Flash 进入睡眠模式
  72   2                      
  73   2      //              PWCON=0xff;     
  74   2      //              PWCON|=0xE4;     
  75   2      //              PWCON|=0x80;    
  76   2                      PWCON|=0x80;            
  77   2                      
  78   2                      
  79   2                      PCON |= 0X02;   //芯片进入 STOP 模式
  80   2                      _nop_();
  81   2                      _nop_();
  82   2                      _nop_();
  83   2                      _nop_();
  84   2                      _nop_();
  85   2                      //等待唤醒，此处可以读STPF来查看唤醒标志        
  86   2              }
  87   1      }
