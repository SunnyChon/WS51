  73          //IIC发送一个字节  
  74          void IIC_Send_Byte(unsigned char txd)
  75          {                        
  76   1              unsigned char t;  
  77   1              IIC_SCL=0;//拉低时钟开始数据传输        
  78   1              for(t=0;t<8;t++)
  79   1              {              
  80   2                      if (txd & 0x80)
  81   2                                      IIC_SDA = 1;
  82   2                      else
  83   2                                      IIC_SDA = 0;
  84   2                                      txd<<=1;          
  85   2                                      delay_us(IIC_CLK_ADJ);  
  86   2                                      IIC_SCL=1;
  87   2                                      delay_us(IIC_CLK_ADJ);  
  88   2                                      IIC_SCL=0;      
  89   2              }                       
  90   1      }           
  91          
  92          //读1个字节  
  93          uint8_t IIC_Read_Byte(void)
  94          {
  95   1              unsigned char i,receive=0;
  96   1              
  97   1              IIC_SDA = 1;            //od pin 输出1表示“读pin”
  98   1              READ_IN;
  99   1              for(i=0;i<8;i++ )
 100   1              {
 101   2                      IIC_SCL=0; 
 102   2                      delay_us(IIC_CLK_ADJ);
 103   2                      
 104   2                      IIC_SCL=1;
 105   2                      receive<<=1;
 106   2                      
 107   2                      if (READ_SDA)
 108   2                                      receive |= 0x01;
 109   2                                      delay_us(IIC_CLK_ADJ); 
 110   2              }
 111   1              
 112   1              IIC_SCL = 0;
 113   1              IIC_SDA=1;
 114   1              READ_OUT;
 115   1              return receive;
 116   1      }
