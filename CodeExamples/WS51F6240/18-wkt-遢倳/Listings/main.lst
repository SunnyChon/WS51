  17          /* S1CON串口1控制寄存器 */
  18          #define SM11    0x80            /* 工作模式选择 */
  19          #define IE1     0x40            /* 中断使能， 1 有效 */
  20          #define SM21    0x20            /* 多机通信使能位， 1 有效 */
  21          #define REN1    0x10            /* 串行接收使能位， 1 有效 */
  22          #define TB81    0x08            /* 发送的第 9 位数据 */
  23          #define RB81    0x04            /* 接收的第 9 位数据 */
  24          #define TI1     0x02            /* 发送中断标志， 1 有效，写 0 清除 */
  25          #define RI1     0x01            /* 接收中断标志， 1 有效，写 0 清除 */
  26          /*****************************************************
  27          *函数名称：void Uart1Mode0(void)
  28          *函数功能：9600波特率
  29          *入口参数：
  30          *出口参数：
  31          *****************************************************/
  32          void Uart1Mode0(void)
  33          {
  34   1              S1CON  = 0x80; 
  35   1              S1RELL = 972;
  36   1              S1RELH = 972>>8;
  37   1      }
  38          
  39          void UART1_write(signed char dat)
  40          {
  41   1          S1BUF = dat;            //Send data to UART buffer
  42   1          while(TI1 != (S1CON&TI1));
  43   1          //清TI1
  44   1          S1CON &= ~TI1;
  45   1      }
  46          
  47          ///重定向c库函数printf到串口，重定向后可使用printf函数
  48          char putchar(char ch)
  49          {
  50   1          /* 发送一个字节数据到串口 */
  51   1          UART1_write((signed char) ch);
  52   1              
  53   1          return ch;
  54   1      }
