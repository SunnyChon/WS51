   5          *函数名称：void Uart0Mode1_Init(void)
   6          *函数功能：8 位异步模式，波特率：可调(T1/T2)
   7          *入口参数：
   8          *出口参数：
   9          *****************************************************/
  10          void Uart0Mode1_Init(void)
  11          {
  12   1          SM00 = 0;
  13   1          SM10 = 1;   //模式选择: 模式1
  14   1                      S0CFG = 0x00;
  15   1          REN0 = 1;   //串行接收使能位
  16   1          RI0 = 0;    //接收中断标志
  17   1          TI0 = 0;    //发送中断标志
  18   1          
  19   1              //TIMER2 作为uart0的波特率时钟源
