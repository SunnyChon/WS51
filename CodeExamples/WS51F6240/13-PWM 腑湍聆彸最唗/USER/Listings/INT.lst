  23   1          T2CH = 65536 - 52 >> 8;//波特率：9600
  24   1          TL2 = T2CL;
  25   1          TH2 = T2CH;
  26   1          TR2 = 1;    //启动定时器2
  27   1          RCLK = 1;   //接收选择定时器2作为波特率发生器
  28   1          TCLK = 1;     //发送选择定时器2作为波特率发生器
  29   1                      ES0 = 1;        /* UART0 中断开 */
  30   1      }
  31          /*****************************************************
  32          *函数名称：void UART0_write(void)
  33          *函数功能：向串口0写一个字节数据
  34          *入口参数：
  35          *出口参数：
  36          *****************************************************/
  37          void UART0_write(int8_t dat)
  38          {
  39   1          S0BUF = dat;            //Send data to UART buffer
  40   1          while(!TI0);
  41   1          TI0 = 0;
  42   1      }
