  94          u8 KEY_Scan(u8 mode)
  95          {        
  96   1              static u8 key_up=1;//按键按松开标志
  97   1              if(mode)key_up=1;  //支持连按             
  98   1              if(key_up&&(KEY0==0||KEY1==0||KEY2==0))
  99   1              {
 100   2                      delay_ms(10);//去抖动15ms 
 101   2                      key_up=0;
 102   2                      if(KEY0==0)return KEY0_PRES;
 103   2                      else if(KEY1==0)return KEY1_PRES;
 104   2                      else if(KEY2==0)return KEY2_PRES;
 105   2              }else if(KEY0==1&&KEY1==1&&KEY2==1)key_up=1;        
 106   1              return 0;// 无按键按下
 107   1      }
