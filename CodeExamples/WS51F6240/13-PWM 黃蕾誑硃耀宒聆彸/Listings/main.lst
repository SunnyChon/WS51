  74          #define P5ZIF1  0x08    //bit3 PWM5 计数器计数到 0 中断标志
  75          #define P6ZIF1  0x20    //bit5 PWM6 计数器计数到 0 中断标志
  76          #define P7ZIF1  0x80    //bit7 PWM7 计数器计数到 0 中断标志
