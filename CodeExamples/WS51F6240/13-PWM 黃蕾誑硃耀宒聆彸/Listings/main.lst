  14          static void delay(int i)
  15          {
  16   1              long j;
  17   1              for(j=0;j<10*i;++j);
  18   1      }
  19          static void delay_1ms(void)
  20          {
  21   1              int j;
  22   1              for(j=0;j<1700;++j);
  23   1      }
  24          
  25          void UART1_write(signed char dat)
  26          {
  27   1          S1BUF = dat;            //Send data to UART buffer
  28   1          while(TI1 != (S1CON&TI1));
  29   1          //清TI1
  30   1          S1CON &= ~TI1;
  31   1      }
  32          
  33          ///重定向c库函数printf到串口，重定向后可使用printf函数
  34          char putchar(char ch)
  35          {
  36   1          /* 发送一个字节数据到串口 */
  37   1          UART1_write((signed char) ch);
  38   1              
  39   1          return ch;
  40   1      }
