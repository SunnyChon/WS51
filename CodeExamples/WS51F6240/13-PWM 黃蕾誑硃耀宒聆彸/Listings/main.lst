  49          void Uart1Mode1(void)
  50          {
  51   1          /*************** UART1 模式1（波特率：9600）****************/
  52   1              S1CON = 0x80;   ///8位异步模式(1), +0x10/中断使能, +0x20/多机通信使能位, +0x40/串行接收使能位
  53   1              S1RELL = 972;
  54   1              S1RELH = 972>>8;        
