  83          void PWM_isr(void) interrupt 5
  84          {
  85   1              P00 = ~P00;
  86   1              //PWMFLG0
  87   1      //      printf("%bx\r", PWMFLG0);
  88   1              if(PWMFLG0 & P0PIF0)    //PWM0 计数器计数到最大值中断标志，仅中心对齐模式下有效
  89   1              {
  90   2      //              P00 = 1;
  91   2                      printf("P0X    \n\r");
  92   2                      PWMFLG0 &= ~P0PIF0;     
  93   2              }
  94   1          if(PWMFLG0 & P0ZIF0)
  95   1              {       
  96   2      //              P00 = 0;
  97   2                      printf("0    \n\r");    //PWM0 计数器计数到 0 中断标志
  98   2                      PWMFLG0 &= ~P0ZIF0;
  99   2              }
 100   1          if(PWMFLG0 & P1ZIF0)
 101   1              {       
 102   2                      printf("1    \n\r");    //PWM1 计数器计数到 0 中断标志
 103   2                      PWMFLG0 &= ~P1ZIF0;
 104   2              }
 105   1          if(PWMFLG0 & P2PIF0)
 106   1              {       
 107   2                      printf("P2X    \n\r");  //PWM2 计数器计数到最大值中断标志，仅中心对齐模式下有效
 108   2                      PWMFLG0 &= ~P2PIF0;
 109   2              }
 110   1          if(PWMFLG0 & P2ZIF0)
 111   1              {       
 112   2                      printf("2    \n\r");    //PWM2 计数器计数到 0 中断标志
 113   2                      PWMFLG0 &= ~P2ZIF0;
 114   2              }
 115   1          if(PWMFLG0 & P3ZIF0)
 116   1              {       
