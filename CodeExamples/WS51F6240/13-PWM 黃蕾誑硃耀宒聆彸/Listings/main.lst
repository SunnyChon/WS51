 141          void PWM_PS_isr(void) interrupt 7
 142          {
 143   1              if(PMSCON & 0x2)        //读掩模标志
 144   1              {
 145   2                      P00 = 1;
 146   2              }
 147   1              else
 148   1              {
 149   2                      P00 = 0;
 150   2              }
 151   1              if(PMSCON & 0x1)
 152   1              {
 153   2                      printf("PS\n");
 154   2                      PMSCON &= ~0x1; 
 155   2              }
 156   1              printf("%bx\n",PMSCON);
 157   1      }
 158          
 159          void PWM_FB_isr(void) interrupt 6
 160          {
 161   1              P00 = 1;
 162   1      //      printf("%bx\n",FBFLG);
 163   1              if(FBFLG & FBPF)        
 164   1              {
 165   2                      printf("FB\n");
 166   2                      FBFLG &= ~FBPF; 
 167   2              }
 168   1              P00 = 0;
 169   1      }
