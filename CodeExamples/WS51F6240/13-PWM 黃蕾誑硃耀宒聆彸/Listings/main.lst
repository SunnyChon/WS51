 119   2              }
 120   1              
 121   1      //      printf("%bx\r", PWMFLG1);
 122   1              //PWMFLG1
 123   1              if(PWMFLG1 & P4PIF1)    //PWM4 计数器计数到最大值中断标志，仅中心对齐模式下有效
