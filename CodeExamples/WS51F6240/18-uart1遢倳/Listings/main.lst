  15          /* S1CON串口1控制寄存器 */
  16          #define SM11    0x80            /* 工作模式选择 */
  17          #define IE1     0x40            /* 中断使能， 1 有效 */
  18          #define SM21    0x20            /* 多机通信使能位， 1 有效 */
  19          #define REN1    0x10            /* 串行接收使能位， 1 有效 */
  20          #define TB81    0x08            /* 发送的第 9 位数据 */
  21          #define RB81    0x04            /* 接收的第 9 位数据 */
  22          #define TI1     0x02            /* 发送中断标志， 1 有效，写 0 清除 */
  23          #define RI1     0x01            /* 接收中断标志， 1 有效，写 0 清除 */
  24          /*****************************************************
  25          *函数名称：void Uart1Mode0(void)
  26          *函数功能：9600波特率
  27          *入口参数：
  28          *出口参数：
  29          *****************************************************/
  30          void Uart1Mode0(void)
  31          {
  32   1              S1CON  = 0x80+0x10+0x40; 
  33   1              S1RELL = 972;
  34   1              S1RELH = 972>>8;
  35   1      }
  36          void UART1_write(signed char dat)
  37          {
  38   1          S1BUF = dat;            //Send data to UART buffer
  39   1          while(TI1 != (S1CON&TI1));
  40   1          //清TI1
  41   1          S1CON &= ~TI1;
  42   1      }
  43          
  44          ///重定向c库函数printf到串口，重定向后可使用printf函数
  45          char putchar(char ch)
  46          {
  47   1          /* 发送一个字节数据到串口 */
  48   1          UART1_write((signed char) ch);
  49   1              
  50   1          return ch;
  51   1      }
