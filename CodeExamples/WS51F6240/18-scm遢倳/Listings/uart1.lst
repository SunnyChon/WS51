   7          /* S1CON串口1控制寄存器 */
   8          #define SM11    0x80            /* 工作模式选择 */
   9          #define IE1     0x40            /* 中断使能， 1 有效 */
  10          #define SM21    0x20            /* 多机通信使能位， 1 有效 */
