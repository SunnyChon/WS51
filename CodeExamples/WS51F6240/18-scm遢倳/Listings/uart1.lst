  20          void Uart1_Isr() interrupt 7
  21          {
  22   1          if(RI1 == (S1CON&RI1))     //如果接收到计算机发的数据
  23   1          {
  24   2              S1CON &= ~RI1;     //清除标志位
  25   2                      dat0 = S1BUF;
  26   2                      Rx_flag = 1;
  27   2          }
  28   1          if(TI1 == (S1CON&TI1))     
  29   1          {
  30   2              S1CON &= ~TI1;     //清除标志位      
  31   2              Tx_flag = 1;
  32   2          }
  33   1      }
  34          
  35          void UART1_write(signed char dat)
  36          {
  37   1          Tx_flag=0;
  38   1          S1BUF = dat;            //Send data to UART buffer
  39   1          while(!Tx_flag);
  40   1      }
