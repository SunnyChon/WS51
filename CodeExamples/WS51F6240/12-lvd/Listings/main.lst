  11          /*********************************lvd简介********************************************
  12          LVD用于监控芯片自身的供电电压VDD，可检测电压范围为 1.8V-4.2V，精度±50mV。
  13          配置寄存器 LVDS 不为 0 时开启 LVD 功能，其触发电压阈值由寄存器 LVDTH 设置。
  14          当芯片 VDD 出现由高变低到 LVDTH 设置的阈值时，LVDF 位将置 1。此时，如果 LVDS 为 1 则产生 LVD 中断，
  15          如果 LVDS 为 2 则产生 LVD 复位，如果 LVDS 为 3 则芯片即不复位也不产生中断，此时通过 LVDF 标志可初步判断
  16          芯片电源电压。如果产生了 LVD 复位，不会复位寄存器 LVDCON。
  17          *************************************************************************************/
  18          
  19          #include "WS51F6240.h"  
  20          #include <stdio.h>
  21          unsigned int j=0;
  22          static void delay(int i)
  23          {
  24   1              long j;
  25   1              for(j=0;j<10*i;++j);
  26   1      }
  27          static void delay_1ms(void)
  28          {
  29   1              int j;
  30   1              for(j=0;j<1700;++j);
  31   1      }
  32          static void delay_10ms(void)
  33          {
  34   1              int j;
  35   1              for(j=0;j<17700;++j);
  36   1      }
  37          
  38          /*****************************************************
  39          *函数名称：void init_lvd(void)
  40          *函数功能：
  41          *入口参数：
  42          *出口参数：
  43          *****************************************************/
  44          void init_lvd(void)
  45          {
  46   1              LVDCON = 0x40;          //低压时产生中断, 低压阈值设置1.8V
  47   1              
  48   1      //  LVRCON = 0x80;              //低压时产生复位, 低压阈值设置1.8V
  49   1              
  50   1      //      LVRCON = 0xC0;          //低压时产生中断不产生中断和复位, 低压阈值设置1.8V
  51   1      }
