  56          void lvd_isr() interrupt 6 
  57          {
  58   1              if((LVDCON&0x01) == 0x01)
  59   1              {
  60   2                      LVDCON  &= 0xFE;
  61   2                      // todo...
  62   2                      P10 = ~P10;
  63   2              }
  64   1      }
  65          
  66          
  67          void main()
  68          {
  69   1         //系统时钟配置
  70   1                      SCCON = 0x00;//选择HRC时钟
  71   1                      HRCON |= 0x80; //HRC使能
  72   1              
  73   1                /****************** 管脚配置 ********************/
  74   1                      P10F = 2; 
  75   1                      P11F = 2; 
  76   1      
  77   1          /*************** LVD 初始化配置 *****************/
  78   1                      init_lvd();
  79   1                      IE = 0xC0;                      //使能LVD中断开 
