  18          void InitHRC(unsigned char sval)
  19          {
  20   1          /* 囀窒HRC奀笘埭,sval(0~15)煦ⅰ */
  21   1              // HRC is the default Clock
  22   1              if(sval>16) return; /* fractional frequency fault */    
  23   1          
  24   1          HCLK_H();           /* select HRC or HOSC */
  25   1          HRE_HRC();          /* seclect HRC */
  26   1          HCLK_DIV(sval-1);   /* set fractional frequency */
  27   1          HRE_EN();           /* enable HRC */
  28   1      }
  29          
