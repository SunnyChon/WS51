  55   1      }
  56          
  57          void InitHOSC(unsigned char sval)
  58          {
  59   1              /* 俋窒 1~16MHz 儒极淥絕けㄗHOSCㄘ */
  60   1              if(sval>16) return;//fractional frequency fault
  61   1          
  62   1              // select HRC or HOSC
  63   1              HCLK_H();    
  64   1              //waiting for HOSC to be stable
  65   1              while(HOSC_STABLE != 1);    
  66   1              // seclect HOSC
  67   1              HRE_HOSC();
  68   1              // set fractional frequency
  69   1              HCLK_DIV(sval-1);    
  70   1              // enable HOSC
  71   1              HOSC_EN();
  72   1              
  73   1      }
  74          void InitLOSC(unsigned char sval)
  75          {
  76   1              if(sval>16) return;//fractional frequency fault
  77   1              // select LOSC or LRC
  78   1              HCLK_L();
  79   1              //waiting for LOSC to be stable
  80   1              while(LOSC_STABLE != 1);
  81   1              // seclect LOSC
  82   1              LRE_LOSC();
  83   1              // set fractional frequency
  84   1              HCLK_DIV(sval-1);
  85   1              // enable HOSC
  86   1              HOSC_EN();
  87   1              
  88   1      }
