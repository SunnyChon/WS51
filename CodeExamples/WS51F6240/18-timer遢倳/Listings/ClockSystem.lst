  42          
  43          void InitLRC(unsigned char sval)
  44          {
  45   1          /* 囀窒 32KHz RC 淥絕け LRC */
  46   1              if(sval>16) return; /* fractional frequency fault */
  47   1          
  48   1              // select LOSC or LRC
  49   1              HCLK_L();
  50   1              // seclect LRC
  51   1              LRE_LRC();
  52   1              HCLK_DIV(sval-1);   /* set fractional frequency */
  53   1              // enable HRC
  54   1              LRE_EN();
