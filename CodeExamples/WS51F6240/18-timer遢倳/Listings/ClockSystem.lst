  90          //========================================================================
  91          // 滲杅: void Init_sysclk(u8 sysclk,u8 sval)
  92          // 鏡扴: 
  93          // 統杅: sysclk:炵苀奀笘恁寁(SYSCLK_HRC,SYSCLK_MRC,SYSCLK_LRC,SYSCLK_HOSC,SYSCLK_LOSC),
  94          //       sval:煦ⅰ炵杅(龰硉1-16)
  95          // 殿隙: 
  96          // 唳掛: 
  97          //========================================================================
  98          void Init_sysclk(u8 sysclk,u8 sval)
  99          {
 100   1          if(sysclk > SYSCLK_LOSC) sysclk = SYSCLK_HRC;
 101   1          
 102   1          if(SYSCLK_HRC == sysclk)
 103   1          {
 104   2              InitHRC(sval);
 105   2          }
 106   1          else if(SYSCLK_MRC == sysclk)
 107   1          {
 108   2              InitMRC(sval);
 109   2          } 
 110   1          else if(SYSCLK_LRC == sysclk)
 111   1          {
 112   2              InitLRC(sval);
 113   2          } 
 114   1          else if(SYSCLK_HOSC == sysclk)
 115   1          {
 116   2              InitHOSC(sval);
