  26          /* S1CON串口1控制寄存器 */
  27          #define SM11    0x80            /* 工作模式选择 */
  28          #define IE1     0x40            /* 中断使能， 1 有效 */
  29          #define SM21    0x20            /* 多机通信使能位， 1 有效 */
  30          #define REN1    0x10            /* 串行接收使能位， 1 有效 */
  31          #define TB81    0x08            /* 发送的第 9 位数据 */
  32          #define RB81    0x04            /* 接收的第 9 位数据 */
  33          #define TI1     0x02            /* 发送中断标志， 1 有效，写 0 清除 */
  34          #define RI1     0x01            /* 接收中断标志， 1 有效，写 0 清除 */
  35          
  36          void UART1_write(signed char dat)
  37          {
  38   1          S1BUF = dat;            //Send data to UART buffer
  39   1          while(TI1 != (S1CON&TI1));
  40   1          //清TI1
  41   1          S1CON &= ~TI1;
  42   1      }
  43          
  44          ///重定向c库函数printf到串口，重定向后可使用printf函数
  45          char putchar(char ch)
  46          {
  47   1          /* 发送一个字节数据到串口 */
  48   1          UART1_write((signed char) ch);
  49   1              
  50   1          return ch;
  51   1      }
