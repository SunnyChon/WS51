  56          void Timer0_isr (void) interrupt 1  
  57          {
  58   1      //    P17=~P17; 
  59   1          /* set timer0 as mode0 (13-bit) */
  60   1          TL0 = (65536-1334) & 0x1F;       //initial timer0 low byte
  61   1          TH0 = (65536-1334) >> 5;         //initial timer0 high byte 
  62   1                P11=~P11;
  63   1      }
  64          void Timer1_isr (void) interrupt 3  
  65          {
  66   1                TL1 = (65536-1334) & 0x1F;              //initial timer0 low byte
  67   1          TH1 = (65536-1334) >> 5;         //initial timer0 high byte
  68   1                P11=~P11;
  69   1      }
  70          
  71          void Timer2_isr (void) interrupt 5  
  72          {
  73   1          /* 请标志 */
  74   1          T2CON &= 0x7f;
  75   1                P11=~P11;
  76   1      }
  77          
  78          
  79          #define TF3     0X80            /* 定时器 3 溢出中断  标志 */
  80          void timer3_isr (void) interrupt 7
  81          { 
  82   1          if(TF3 == (T3CON&TF3))      //溢出中断标志
  83   1          {
  84   2              //淸中断
  85   2              T3CON &= ~TF3;
  86   2              P11 = ~P11;
  87   2          }
  88   1      }
