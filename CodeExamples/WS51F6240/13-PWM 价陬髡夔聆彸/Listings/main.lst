  26          /*****************************************************
  27          * 中断服务函数
  28          *****************************************************/
  29          void Uart_Isr() interrupt 4
  30          {
  31   1          if(RI0 == 1)     //如果接收到计算机发的数据
  32   1          {
  33   2              RI0 = 0;     //清除标志位
  34   2          }
  35   1          if(TI0 == 1)     //如果接收到计算机发的数据
  36   1          {
  37   2              TI0 = 0;     //清除标志位 
  38   2              Tx_flag = 1;
  39   2          }
  40   1      }
  41          
  42          void UART1_write(signed char dat)
  43          {
  44   1          S1BUF = dat;            //Send data to UART buffer
  45   1          while(TI1 != (S1CON&TI1));
  46   1          //清TI1
  47   1          S1CON &= ~TI1;
  48   1      }
  49          
  50          ///重定向c库函数printf到串口，重定向后可使用printf函数
  51          char putchar(char ch)
  52          {
  53   1          /* 发送一个字节数据到串口 */
  54   1          UART1_write((signed char) ch);
