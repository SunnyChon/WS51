  81          #define P0ZIF0  0x02    //bit1 PWM0 计数器计数到 0 中断标志
  82          #define P1ZIF0  0x08    //bit3 PWM1 计数器计数到 0 中断标志
  83          #define P2PIF0  0x10    //bit4 PWM2 计数器计数到最大值中断标志，仅中心对齐模式下有效
  84          #define P2ZIF0  0x20    //bit5 PWM2 计数器计数到 0 中断标志
  85          #define P3ZIF0  0x80    //bit7 PWM3 计数器计数到 0 中断标志
