  90          #define P5ZIF1  0x08    //bit3 PWM5 计数器计数到 0 中断标志
  91          #define P6ZIF1  0x20    //bit5 PWM6 计数器计数到 0 中断标志
  92          #define P7ZIF1  0x80    //bit7 PWM7 计数器计数到 0 中断标志
  93          
  94          // 寄存器 FBFLG 标志
  95          #define FBPF    0x04            //P14 刹车引脚刹车信号引起刹车中断标志
  96          #define FBAF    0x02            //ADC 比较结果刹车信号引起刹车中断标志
  97          #define FBCF    0x01            //ADC 比较结果刹车信号引起刹车中断标志
