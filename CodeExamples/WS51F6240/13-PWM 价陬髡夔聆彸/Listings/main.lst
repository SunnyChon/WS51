  65          void Uart1Mode1(void)
  66          {
  67   1          /*************** UART1 模式1（波特率：9600）****************/
  68   1              S1CON = 0x80;   ///8位异步模式(1), +0x10/中断使能, +0x20/多机通信使能位, +0x40/串行接收使能位
  69   1              S1RELL = 972;
  70   1              S1RELH = 972>>8;        
  71   1      }
