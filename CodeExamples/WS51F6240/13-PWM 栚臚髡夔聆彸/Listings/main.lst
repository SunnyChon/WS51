  26          void UART1_write(signed char dat)
  27          {
  28   1          S1BUF = dat;            //Send data to UART buffer
  29   1          while(TI1 != (S1CON&TI1));
  30   1          //清TI1
  31   1          S1CON &= ~TI1;
  32   1      }
  33          
  34          ///重定向c库函数printf到串口，重定向后可使用printf函数
  35          char putchar(char ch)
  36          {
  37   1          /* 发送一个字节数据到串口 */
  38   1          UART1_write((signed char) ch);
  39   1              
  40   1          return ch;
  41   1      }
  42          /*****************************************************
