  11          /*********************************WDT简介********************************************
  12          看门狗定时器（WDT）为一个 15 位递减计数器，
  13          其计数时钟为 LRC /LOSC 时钟，有 8 位调节精度，计数范围为 7.8125ms-1s。
  14          *************************************************************************************/
  15          #include "WS51F6240.h"  
  16          static void delay_1ms(void)
  17          {
  18   1              int j;
  19   1              for(j=0;j<1700;++j);
  20   1      }
  21          /*****************************************************
  22          *函数名称：init_wdt(void)
  23          *函数功能：wdt复位
  24          *入口参数：
  25          *出口参数：
  26          *****************************************************/
  27          void rest_wdt(void)
  28          {
  29   1                      WDTCON = 0x07;    //产生复位 1s
  30   1      //      WDTCON = 0x06;    //产生复位 500ms
  31   1      //      WDTCON = 0x05;    //产生复位 250ms
  32   1      //      WDTCON = 0x04;    //产生复位 125ms
  33   1      //      WDTCON = 0x03;    //产生复位 62.5ms
  34   1      //      WDTCON = 0x02;    //产生复位 31.25ms
  35   1      //      WDTCON = 0x01;    //产生复位 15.625ms
  36   1      //      WDTCON = 0x00;    //产生复位 7.8125ms   
  37   1          WDTFLG = 0xA5;              //开启  
  38   1      }
  39          
  40          /*****************************************************
  41          *函数名称：init_wdt(void)
  42          *函数功能：wdt中断
  43          *入口参数：
  44          *出口参数：
  45          *****************************************************/
  46          void exint_wdt(void)
  47          {
  48   1                WDTCON = 0x87;    //产生中断 1s     + 0x40  //选择LOSC时钟
  49   1      //      WDTCON = 0x86;    //产生中断 500ms
  50   1      //      WDTCON = 0x85;    //产生中断 250ms
