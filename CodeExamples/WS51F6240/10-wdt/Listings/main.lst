  58          /*****************************************************
  59          中断函数
  60          *****************************************************/
  61          void Wdt_Isr() interrupt 6
  62          {
  63   1              if((WDTFLG&0x02) == 0x02)
  64   1              {
  65   2                      WDTFLG = 0xA5;  //喂狗
  66   2                      P11 = ~P11;
  67   2              }
  68   1      }
