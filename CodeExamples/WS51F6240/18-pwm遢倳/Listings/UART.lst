C51 COMPILER V9.59.0.0   UART                                                              06/10/2019 14:34:42 PAGE 2   

  55              ---------------------------------------------------------------
  56              模式0(同步移位模式)         波特率:Fsys/12 (倍频无效)
  57              模式1(8 位异步模式)         波特率:baudrate = 定时器溢出率/32 
  58              模式2(9 位异步模式)         波特率:
  59                                              当 SMOD＝0 时，波特率为 Fsys/64
  60                                              当 SMOD＝1 时，波特率为 Fsys/32
  61              模式3(9 位异步模式)         波特率:baudrate = 定时器溢出率/32 
  62              ---------------------------------------------------------------
  63          
  64          FSYS = 16MHz频率  UART模式1/3，时钟源-定时器1/2, 
  65          
  66          波特率: baudrate = 定时器溢出率/32 
  67          
  68          定时器计数值: Val = Fsys/32/波特率；(例：16000000/32/115200=4.34)
  69                                              (例：2*16000000/32/115200=8.68)倍频
  70          倍频： #define SMOD        0x80
  71          
  72          溢出率：f2(MHz) = 16/(65536 - T2VAL)
  73          
  74          波特率: baudrate = f2/32 
  75                                             T2波特率输出计数值     倍频                T1(256) 16/12
  76              波特率         溢出率          计数值   重载值        计数值   重载值     计数值   重载值 
  77              4800  *  32 =  0.1536（MHz）   104      65432                             8.68
  78              9600  *  32 =  0.3072（MHz）   52       65484                             4.34       
  79              14400 *  32 =  0.4608（MHz）   34.72                                      2.89
  80              19200 *  32 =  0.6144（MHz）   26       65510
  81              28800 *  32 =  0.9216（MHz）   17.36
  82              38400 *  32 =  1.2288（MHz）   13       65523
  83              56000 *  32 =  1.7920（MHz）   8.93
  84              57600 *  32 =  1.8432（MHz）   8.68
  85              115200 * 32 =  3.6864（MHz）   4.34                   8.68     65527
  86          */
  87          
  88          /* ====================================================================
  89          /* USART0  快速波特率设置(修改分频系数)
  90              由于系统时钟是固定的，要达到更准确的波特率，只能通过修改分频系数来实现
  91              通过设置 UDE=1 来使能， DNUM 的数值表示不同的分频系数，详见寄存器 UDCKS 描述。
  92              要注意的是，当 UDE=1 时， SMOD 位（PCON[7]）将不起作用。
  93              
  94          波特率: baudrate = Fsys/定时器计数值/分频系数     
  95                  分频系数 = Fsys/定时器计数值/baudrate
  96                  
  97                  定时器2      波特率       分频系数       
  98                               115200          28             16000000/115200/5=27.78        
  99          */
 100          
