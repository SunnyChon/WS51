  31          void Uart0_Isr(void) interrupt UART0_VECTOR
  32          {
  33   1          if(RI0 == 1)     //如果接收到计算机发的数据
  34   1          {
  35   2              num = S0BUF;
  36   2              num++; 
  37   2              if(num != 0x56)
  38   2              {
  39   3                  num = 0x33;
  40   3              }
  41   2              RI0 = 0;     //清除标志位
  42   2              S0BUF = num; //把数据加1后再发送给计算机
  43   2          }
  44   1          
  45   1          if(TI0 == 1)     //如果发送完毕
  46   1          {
  47   2              TI0 = 0;     //清除标志位
  48   2              com_tx_busy = 0;
  49   2          }
  50   1      }
