  17          *ČëżÚ˛ÎĘýŁşSectorAddr_ÉČÇřĘ×µŘÖ·(NVR1/2/3/4_START_ADDR)
  18          *łöżÚ˛ÎĘýŁşvoid
  19          *****************************************************/
  20          void EraseNVR(unsigned short SectorAddr)
  21          {
  22   1              //1  Flash unlock
  23   1              FSFLG=NVR_UNLOCK;
  24   1      
  25   1              //2  write address
  26   1              FSADRL=(SectorAddr&0xff);
  27   1              FSADRH=((SectorAddr>>8)&0xff);
  28   1              //3  Flash erase cmd
  29   1              FSCMD=NVR_ERASE;
  30   1              //4 NVR lock
  31   1              FSFLG=NVR_LOCK;
  32   1      }
  33          /*****************************************************
  34          *şŻĘýĂűłĆŁşvoid WriteDataNVR(unsigned char *buf,unsigned short SectorAddr,unsigned short len)
  35          *şŻĘýą¦ÄÜŁşNVRÉČÇřĐ´
  36          *ČëżÚ˛ÎĘýŁşbuf,ŇŞĐ´ČëĘýľÝµÄÖ¸Őë
