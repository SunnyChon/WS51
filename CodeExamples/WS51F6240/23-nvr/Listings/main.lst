  60          *ШыПкВЮЪ§ЃКnum
  61          *ГіПкВЮЪ§ЃКvoid
  62          *****************************************************/
  63          void writeHex(unsigned char num)
  64          {
  65   1              unsigned char i=0;
  66   1              i=num/16;
  67   1              if(i>9)UART0_write(i-10+'A');
  68   1              else UART0_write(i+'0');
  69   1              i=num%16;
  70   1              if(i>9)UART0_write(i-10+'A');
  71   1              else UART0_write(i+'0');
  72   1              UART0_write(' ');
  73   1      }
