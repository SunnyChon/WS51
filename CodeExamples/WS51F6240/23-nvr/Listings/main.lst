 253          /*****************************************************
 254          *КЏЪ§УћГЦЃКvoid nvrCkSumTest(void)
 255          *КЏЪ§ЙІФмЃКflash ЕФРлМгКЭМФДцЦїВтЪд 
 256          *ШыПкВЮЪ§ЃКvoid
 257          *ГіПкВЮЪ§ЃКvoid
 258          *****************************************************/
 259          void nvrCkSumTest(void)
 260          {
 261   1              unsigned int i,k;
 262   1              unsigned char j;        
 263   1              for(i=0;i<16;++i)
 264   1              {
 265   2                      FSDARL=((i*SECTOR_SIZE)&0xff);
 266   2                      FSDARH=(((i*SECTOR_SIZE)>>8)&0xff);
 267   2                      FSCMD=0x8c;
 268   2                      printf("i= %d, %bx_%bx", i, CKSUMH,CKSUML);
 269   2                      
 270   2                      //ЖСnvrЧјгђ
 271   2                      for(k=0;k<SECTOR_SIZE;++k)rbuf[k]=0;
 272   2                      readDatafromNVR(rbuf,(i*SECTOR_SIZE),SECTOR_SIZE);
 273   2                      k=0;
 274   2                      for(j=0;j<SECTOR_SIZE;++j)
 275   2                      {
 276   3                              k += rbuf[j];
 277   3                      }
 278   2                      
 279   2                      j=k>>8;
 280   2                      printf(" %bx",j);
 281   2                      j=k&0xff;
 282   2                      printf("_%bx",j);
 283   2                      UART0_write('\r');
 284   2                      UART0_write('\n');
 285   2              }
 286   1      }  
