  20          void EraseNVR(unsigned short SectorAddr)
  21          {
  22   1              //1  Flash unlock
  23   1              FSFLG=NVR_UNLOCK;
  24   1      
  25   1              //2  write address
  26   1              FSDARL=(SectorAddr&0xff);
