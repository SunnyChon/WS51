  41          void WriteDataNVR(unsigned char *buf,unsigned short SectorAddr,unsigned short len)
  42          {
  43   1              unsigned char i=0;
  44   1              //1  Flash unlock
  45   1              FSFLG=NVR_UNLOCK;
  46   1              //2  Flash  write cmd
  47   1              FSCMD=NVR_WRITE;        
  48   1              for(i=0;i<len;++i)
  49   1              {
  50   2                      //3  write address              
  51   2                      FSDARL=(SectorAddr&0xff);
  52   2                      FSDARH=((SectorAddr>>8)&0xff);
  53   2                      SectorAddr++;
  54   2                      //4 write data
  55   2                      FSDAT=buf[i];
  56   2              }
  57   1              //4 NVR lock
  58   1              FSFLG=NVR_LOCK;
  59   1      }
  60          
