 121   1              //4 NVR lock
 122   1              FSFLG=NVR_LOCK;
 123   1      }
 124          void readDatafromNVR(unsigned char *buf,unsigned short SectorAddr,unsigned short len)
 125          {
 126   1              unsigned char i=0;
 127   1              
 128   1              FSFLG = NVR_UNLOCK;
 129   1              //1  read cmd
 130   1              FSCMD=NVR_READ;
 131   1              for(i=0;i<len;++i)
 132   1              {
 133   2                      //2  write address              
 134   2                      FSDARL=(SectorAddr&0xff);
 135   2                      FSDARH=((SectorAddr>>8)&0xff);
 136   2                      ++SectorAddr;
 137   2                      //3 read data
 138   2                      buf[i]=FSDAT;
 139   2              }
 140   1      }
 141          
 142          void WriteDataNVR(unsigned char *buf,unsigned short SectorAddr,unsigned short len)
 143          {
 144   1              unsigned char i=0;
 145   1              //1  Flash unlock
 146   1              FSFLG=NVR_UNLOCK;
 147   1              //2  Flash  write cmd
 148   1              FSCMD=NVR_WRITE;        
 149   1              for(i=0;i<len;++i)
 150   1              {
 151   2                      //3  write address              
 152   2                      FSDARL=(SectorAddr&0xff);
 153   2                      FSDARH=((SectorAddr>>8)&0xff);
 154   2                      SectorAddr++;
 155   2                      //4 write data
 156   2                      FSDAT=buf[i];
 157   2              }
 158   1              //4 NVR lock
 159   1              FSFLG=NVR_LOCK;
 160   1      }
