 111          void EraseNVR(unsigned short SectorAddr)
 112          {
 113   1              //1  Flash unlock
 114   1              FSFLG=NVR_UNLOCK;
 115   1      
 116   1              //2  write address
C51 COMPILER V9.59.0.0   MAIN                                                              07/14/2022 10:06:13 PAGE 3   

 117   1              FSDARL=(SectorAddr&0xff);
