  10          #include "WS51F6240.h"  
  11          
  12          /* 
  13          * timer0和timer1, 进入中断函数会自动清标志
  14          * Timer0: 模式选择
  15          *                       (1).模式0: 定时器 0 作为 13 位定时器/计数器
  16          *               (2).模式1: 定时器 0 作为 16 位定时器/计数器
  17          *               (3).模式2: 定时器 0 作为 8 位自动重载定时器/计数器
  18          *               (4).模式3: TL0 和 TH0 作为两个独立的 8 位定时器/计数器
  19          * Timer1: 模式选择
  20          *                       (1).模式0: 定时器 1 作为 13 位定时器/计数器
  21          *               (2).模式1: 定时器 1 作为 16 位定时器/计数器
  22          *               (3).模式2: 定时器 1 作为 8 位自动重载定时器/计数器
  23          *               (4).模式3: 此模式下，TH1、TL1 会被锁住，等效于 TR1=0。
  24          * Timer0/1: 管脚配置
  25          *               (1).计数功能, 管脚T0(P05)设置为输入(P05F = 0x1;)
  26          *               (2).计数功能, 管脚T1(P00)设置为输入(P00F = 0x1;)
  27          
  28                          定时时间 = ((最大计数值-初始值)*12*1000*1000) / 晶振频率
  29                          初始值   =  定时时间*晶振频率/分频系数
  30                          晶振频率(16*1000*1000 或 32*1000)
  31          */
  32          
  33          
  34          static void delay_1ms(void)
  35          {
  36   1              int j;
  37   1              for(j=0;j<1700;++j);
  38   1      }
  39          
  40          static void delay_10ms(void)
  41          {
  42   1              int j;
  43   1              for(j=0;j<17700;++j);
  44   1      }
  45          
  46          /*****************************************************
  47          *函数名称：void init_timer1(void)
  48          *函数功能：Timer1初始化配置
  49          *入口参数：
  50          *出口参数：
  51          *****************************************************/
  52          void init_timer1(void)
  53          {       
  54   1              //工作模式0：13 位定时器/计数器，计满6.1440ms(13bit)
C51 COMPILER V9.59.0.0   MAIN                                                              07/26/2021 15:43:35 PAGE 2   

  55   1          TL1 = (8192-1334) & 0x1F;       //初始值低字节，TL1 的高 3 位是无效的
  56   1          TH1 = (8192-1334) >> 5;         //初始值高字节(1ms@16MHz)
  57   1          TMOD = 0x00;                          //定时器,时钟为系统时钟 12 分频 
  58   1              
  59   1              //工作模式1：16 位定时器，计满49.152ms(16bit)
  60   1      //    TL1 = (65536-1334);       
  61   1      //    TH1 = (65536-1334) >> 8;      
  62   1      //    TMOD = 0x10;                                                              //模式，+0x40计数定时选择，+0x08门控选择
  63   1      
  64   1              //工作模式2：8 位自动重载定时器，计满0.19125ms(8bit)
  65   1      //    TH1 = 0;       
  66   1      //    TL1 = 256-134 ;                                                   //重载值为(256-134); 定时100us  
  67   1      //    TMOD = 0x20;
  68   1      
  69   1              //工作模式3：2个 8 位定时器 TR1=0;
  70   1      //    TL1 = 0;       
  71   1      //    TH1 = 0;      
  72   1      //    TMOD = 0x30;                                                              //模式，+0x40计数定时选择，+0x08门控选择
  73   1                                                                      
  74   1          ET1 = 1;    //开中断 定时器 1 中断使能控制位
  75   1          EA = 1;             //总中断
  76   1          TR1 = 1;    //启动定时器
  77   1      }
