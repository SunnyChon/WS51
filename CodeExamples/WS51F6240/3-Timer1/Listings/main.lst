  83          void timer1_isr (void) interrupt 3  
  84          {
  85   1          /* set timer1 as mode0 (13-bit) */
  86   1          TL1 = (8192-1334) & 0x1F;       //初始值低字节，TL0 的高 3 位是无效的
  87   1          TH1 = (8192-1334) >> 5;         //初始值高字节(1ms@16MHz)
  88   1              
  89   1              /* 工作模式1：16 位定时器 */
  90   1      //    TL1 = (65536-1334);       
  91   1      //    TH1 = (65536-1334) >> 8;  
  92   1      //      
  93   1              /* 工作模式2：8 位自动重载定时器,重载寄存器 TH1 */  
  94   1      //        TH1 = 0;       
  95   1      //    TL1 = 256-134;    //重载值为(256-134); 定时100us
  96   1              
  97   1              /* 工作模式3：两个 8 位定时器(TL1,TH1) */
  98   1      //    TL1 = 0; 
  99   1              
 100   1                  P10 = ~P10;
 101   1      }
